/**
 * @param {string} haystack
 * @param {string} needle
 * @return {number}
 */
var strStr = function(haystack, needle) {
    let i = 0;
    for (let letter of haystack){
        if (letter === needle[0] && haystack.slice(i, i + needle.length) === needle){
            return i;
        }
        i++;
    }
    return -1;
};